# LLM 配置（多源支持）
# 模式: single=单源, multi=多源并发
LLM_MODE=single
LLM_PROVIDER=deepseek
MULTI_PROVIDERS=deepseek,minimax

# DeepSeek
PROVIDER_DEEPSEEK_API_KEY=your-deepseek-api-key
PROVIDER_DEEPSEEK_MODEL=deepseek-chat
PROVIDER_DEEPSEEK_BASE_URL=https://api.deepseek.com

# MiniMax
PROVIDER_MINIMAX_API_KEY=your-minimax-api-key
PROVIDER_MINIMAX_MODEL=MiniMax-M2.7
PROVIDER_MINIMAX_BASE_URL=https://api.minimaxi.com/v1

# OpenAI
PROVIDER_OPENAI_API_KEY=your-openai-api-key
PROVIDER_OPENAI_MODEL=gpt-4o
PROVIDER_OPENAI_BASE_URL=https://api.openai.com/v1

# 全局参数
LLM_TEMPERATURE=1.0
LLM_MAX_TOKENS=2048

# 应用环境
APP_ENV=dev
DEBUG=true

# 服务器配置
HOST=0.0.0.0
PORT=8000

# Redis 配置
REDIS_URL=redis://localhost:6379/0

# 对话记忆配置
MEMORY_MAX_ROUNDS=10
MEMORY_TTL=3600

# RAG 配置
RAG_MOCK_ENABLED=true
RAG_BASE_URL=http://localhost:8081/api
RAG_TOP_K=5
RAG_TIMEOUT=10
RAG_RELEVANCE_THRESHOLD=0.6

# Agent 配置
MAX_QUERY_LENGTH=500
MAX_AGENT_STEPS=3

# 启用的业务域
ENABLED_DOMAINS=["admission"]
