# OpenAI API 配置
OPENAI_API_KEY=your-api-key-here
OPENAI_MODEL=gpt-4o
OPENAI_BASE_URL=https://api.openai.com/v1

# 应用环境
APP_ENV=dev
DEBUG=true

# 服务器配置
HOST=0.0.0.0
PORT=8000

# Redis 配置
REDIS_URL=redis://localhost:6379/0

# 对话记忆配置
MEMORY_MAX_ROUNDS=10
MEMORY_TTL=3600

# RAG 配置
RAG_MOCK_ENABLED=true
RAG_BASE_URL=http://localhost:8081/api
RAG_TOP_K=5
RAG_TIMEOUT=10
RAG_RELEVANCE_THRESHOLD=0.6

# Agent 配置
MAX_QUERY_LENGTH=500
MAX_AGENT_STEPS=3

# 启用的业务域
ENABLED_DOMAINS=["admission"]
